{
  "name": "maranto-sws-tests",
  "private": true,
  "description": "Test suite for maranto-sws.github.io — behavioral, a11y, visual regression, and content integrity",
  "scripts": {
    "build": "bash scripts/build.sh",
    "test": "node tests/content-integrity.js && playwright test",
    "test:content": "node tests/content-integrity.js",
    "test:behavioral": "playwright test --grep-invert \"Visual Regression\"",
    "test:visual": "playwright test --grep \"Visual Regression\"",
    "test:update-snapshots": "playwright test --grep \"Visual Regression\" --update-snapshots",
    "test:ci": "node tests/content-integrity.js && playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.0",
    "@playwright/test": "^1.44.0"
  }
}
